# Dev environment configuration - ready to use with `cp .env.dev .env && docker compose up`
# Uses Anvil default accounts for local development.
# Only non-default values are listed here. See .env.template for all options.

INTERNAL_NETWORK_SUBNET='10.10.40.0/24'

# Executor parameters (default: vsock, need tcp for Docker)
CHANNEL_TYPE='tcp'
EXECUTOR_IP_HOST='10.10.40.10'
EXECUTOR_ADMIN_PORT='9080'
# Fixed executor keys for dev (deterministic keyset, matches TEE_SIGNER_ADDRESS and TEE_PUB_P521 below)
EXECUTOR_FIXED_SIGNING_KEY='79ec8072d24d68aaabf6dbe06416d635b66bf6042847d447a5a14f867b2da7cf'
EXECUTOR_FIXED_COMMUNICATION_KEY='00b2df45d29db7b6a314100cbff4abde8106254204205eb0653662a5fc41a6e48ba0deceb2b830b546ec4dd1fa62b7e9a5b79aee0bf695f67c0642e8ddc7be91352b'
EXECUTOR_FIXED_STATE_KEY='74ffca703f8c04292a849bfc7c6389f4e193ac13300896a74c319753c2f1f66a'

# Manager parameters
MANAGER_IP_HOST='10.10.40.20'
# Anvil Account #2 private key
MANAGER_KEY_SECP256='5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a'
MANAGER_DATA_FOLDER='/data'
MANAGER_INPUT_WASMS='/input_wasms'
MANAGER_REPORTS_FOLDER='/reports'

# Authority service parameters
AUTHORITY_SERVICE_IP_ADDRESS='10.10.40.40'
CHAIN_ID='31337'
AUTHORITY_SERVICE_SUBGRAPH_URL='http://subgraph-node:8000/subgraphs/name/hcce'

# Chain parameters
CHAIN_RPC_PROTOCOL='http'
CHAIN_RPC_ADDRESS='10.10.40.30'
CHAIN_RPC_PORT='8545'
# Auto-populated by the deployer container at startup
CHAIN_PROCESSOR_ADDRESS='0x0000000000000000000000000000000000000000'
CHAIN_TEEAUTHENTICATOR_ADDRESS='0x0000000000000000000000000000000000000000'

# Log server (points to manager IP)
LOG_SERVER_IP_HOST='10.10.40.20'

# Deployer parameters (Anvil default accounts)
# Anvil Account #0 private key (deployer + admin)
DEPLOYER_PRIVATE_KEY='0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80'
DEPLOYER_ADMIN='0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266'
# Manager address used as UPDATE_STATUS_OPERATOR (Anvil Account #2)
UPDATE_STATUS_OPERATOR='0x3C44CdDdB6a900fa2b585dd299e03d12FA4293BC'
# TEE: use NoAttestationTeeAuthenticator for dev (no Nitro attestation needed)
TEE_NO_ATTESTATION='true'
# Derived from EXECUTOR_FIXED_SIGNING_KEY
TEE_SIGNER_ADDRESS='0x2a0fba02cee7fb70899648037c7E8203881e2D55'
# Derived from EXECUTOR_FIXED_COMMUNICATION_KEY (uncompressed P521 public key, 133 bytes)
TEE_PUB_P521='0x040169e59d61259de5a058803f45aae58beeeec1511b9617aa896bc923ec11347cbb84c580793d424971c53d90dfe2f91266179146bb355a75c6ce537acbb2d5e02a8a011833655720c92a674e054c92d81604eacc25513d524f51caa5d6741129b2ed4be9dfe351174d53a062afba6eaf5775c5ae0e4c351033e583f8b873493ec8b45f58'
MIN_FEE_PER_REQUEST='10'
